model SalaryLog {
  id          Int      @id @default(autoincrement())
  branchId    Int
  salaryId    Int
  action      String // CREATED / UPDATED / DELETED
  data        Json
  ip          String?
  updatedById Int?
  createdAt   DateTime @default(now())
  salary      Salary   @relation(fields: [salaryId], references: [id])
}

model SalaryStructure {
  id           Int      @id @default(autoincrement())
  branchId     Int
  basicSalary  Float    @default(0)
  houseRent    Float    @default(0)
  medical      Float    @default(0)
  transport    Float    @default(0)
  food         Float    @default(0)
  casualLeave  Int      @default(0)
  medicalLeave Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  branch       Branch   @relation(fields: [branchId], references: [id])
}

model LeaveDaySetup {
  id           Int          @id @default(autoincrement())
  branchId     Int
  name         String
  days         Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  branch       Branch       @relation(fields: [branchId], references: [id])
  leaveApplies LeaveApply[]
}

model LeaveApply {
  id              Int           @id @default(autoincrement())
  branchId        Int
  employeeId      Int
  status          ChequeStatus  @default(Pending)
  leaveId         Int
  leaveLeft       Int
  fromDays        DateTime
  toDays          DateTime
  applyDays       Int
  approveDays     Int?
  approveFromDate DateTime?
  approveToDate   DateTime?
  note            String?
  subject         String
  content         String        @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  branch          Branch        @relation(fields: [branchId], references: [id])
  employee        Employee      @relation(fields: [employeeId], references: [id])
  leaveType       LeaveDaySetup @relation(fields: [leaveId], references: [id])
}

model Salary {
  id                Int      @id @default(autoincrement())
  branchId          Int
  employeeId        Int
  paymentAccountId  Int
  month             Int // 1 - 12
  year              Int
  grossSalary       Float    @default(0)
  weekendAllowance  Float    @default(0)
  holidayAllowance  Float    @default(0)
  bonus             Float    @default(0)
  provident         Float    @default(0)
  advance           Float    @default(0)
  lateFee           Float    @default(0)
  absentFee         Float    @default(0)
  unauthorizedLeave Float    @default(0)
  deduct            Float    @default(0)
  paymentAmount     Float    @default(0)
  note              String?
  createdById       Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  branch     Branch      @relation(fields: [branchId], references: [id])
  employee   Particular  @relation("employee", fields: [employeeId], references: [id])
  payment    Particular  @relation("account", fields: [paymentAccountId], references: [id])
  salaryLogs SalaryLog[]
  vouchers   Voucher[]

  particularId Int?

  @@unique([branchId, employeeId, month, year])
}
