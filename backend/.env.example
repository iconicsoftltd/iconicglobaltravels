# =========================
# APP CONFIG
# =========================
# In Docker Compose, PORT is set to 5000 by compose; keep this aligned for local non-Docker runs.
PORT=5000
NODE_ENV=development

# Optional: comma-separated extra CORS origins (merged in app.ts). Set your public site URL for VPS.
# Example: https://app.example.com
CORS_ORIGINS=

# =========================
# DATABASE
# =========================
DATABASE_URL="mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME"

# =========================
# AUTH
# =========================
AUTH_TOKEN=your_auth_token_secret
AUTH_TOKEN_EXPIRES_IN=15d

REFRESH_TOKEN=your_refresh_token_secret
REFRESH_TOKEN_EXPIRES_IN=30d

# =========================
# CLOUDINARY (or similar)
# =========================
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_cloud_api_key
CLOUD_SECRET_KEY=your_cloud_secret_key

# =========================
# EMAIL SERVICE
# =========================
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password

# =========================
# OTP CONFIG
# =========================
OTP_TOKEN=your_otp_secret
OTP_TOKEN_EXPIRES_IN=5m

# =========================
# CLIENT URL
# =========================
CLIENT_URL=http://localhost:3000

# Note: docker-compose.yml overrides DATABASE_URL to use the MySQL service `db`.