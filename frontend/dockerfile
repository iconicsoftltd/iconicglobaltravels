# ================================================================
#  Frontend Dockerfile
#  Stack: React + TypeScript + Vite
# ================================================================

# ── Stage 1: Development (Vite HMR) ────────────────────────────
FROM node:20-alpine AS development

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 3000

# Reason: Dev server bind/port are set in vite.config.ts (`server.host` / `server.port`).
CMD ["npm", "run", "dev"]


# ── Stage 2: Builder (production build) ────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

RUN npm run build


# ── Stage 3: Production (Nginx static file serve) ─────────────
FROM nginx:alpine AS production

# Reason: Vite outputs to dist/, not CRA's build/
COPY --from=builder /app/dist /usr/share/nginx/html

# React Router (SPA) — add nginx.conf before using production target
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
