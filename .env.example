# =============================================================================
# Root-level Docker Compose / VPS environment
# Copy to `.env` in the project root and adjust values.
# =============================================================================

# Public domain (DNS A/AAAA record must point to this VPS). Used when configuring
# host Nginx / Certbot on the VPS — not interpolated by docker-compose.yml.
DOMAIN=app.example.com

# Full API base URL the browser will call (must match nginx + backend routes).
# Use HTTPS in production after certs are issued.
VITE_API_URL=https://app.example.com/api/v1

# MySQL (used by Compose for db service and DATABASE_URL construction)
DB_ROOT_PASSWORD=change_me_root
DB_NAME=erp_accounts
DB_USER=erp_user
DB_PASSWORD=change_me_user

# Node environment for containers (development = ts-node-dev + Vite dev server)
NODE_ENV=development

# Optional: extra CORS origins for the API (comma-separated). Merged with defaults in backend/src/app.ts.
# Example: https://app.example.com,http://127.0.0.1:3000
CORS_ORIGINS=
